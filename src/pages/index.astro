---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar';
import GlobeTeaser from '../components/GlobeTeaser';
import Footer from '../components/Footer';

// Server-rendered home page - all content in initial HTML for SEO
export const prerender = false;
---

<Base>
  <Navbar />
  
  <main>
    {/* Hero Section */}
    <section id="hero" class="relative h-screen min-h-[600px] flex flex-col overflow-hidden">
      <div class="absolute inset-0 overflow-hidden">
        <div
          class="absolute inset-0 bg-cover bg-center bg-no-repeat"
          style="background-image: url('/images/PICT3320.JPG');"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/40" />
      </div>

      <div class="relative flex flex-col h-full justify-between">
        {/* Tagline at top */}
        <div class="pt-12 px-6 md:px-12">
          <p class="text-white text-2xl md:text-4xl font-light leading-relaxed max-w-3xl">
            Understanding how large-scale systems shape global futures
          </p>
        </div>

        {/* Bottom content */}
        <div class="pb-16 px-6 md:px-12 flex justify-between items-end">
          <div class="max-w-2xl">
            <h1 class="text-white text-5xl md:text-6xl font-light leading-tight mb-4">
              TransHorizons
            </h1>
            <p class="text-white/80 text-lg md:text-xl font-light">
              Research on geopolitics, resources, technology, and Canada's place in evolving systems
            </p>
          </div>
          <div class="hidden md:block text-right">
            <p class="text-white/60 text-sm">Scroll to explore</p>
          </div>
        </div>
      </div>
    </section>

    {/* Globe Teaser - Interactive React Island */}
    <section id="globe" class="py-16 md:py-24 bg-[#EFEFEF]">
      <div class="container mx-auto px-6">
        <GlobeTeaser client:only="react" />
      </div>
    </section>

    {/* Portfolio Section */}
    <section id="portfolio" class="py-16 md:py-24 bg-white">
      <div class="container mx-auto px-6 md:px-12">
        <div class="max-w-4xl">
          <h2 class="text-4xl md:text-5xl font-light mb-12 text-charcoal">
            Analytical Essays
          </h2>

          <div class="grid gap-8 md:gap-12">
            {/* Geopolitics Essay */}
            <article class="border-b border-gray-200 pb-8 md:pb-12">
              <div class="flex flex-col md:flex-row gap-6 md:gap-12">
                <div class="flex-1">
                  <p class="text-sm text-gray-500 mb-2">PORTFOLIO · MARCH 2026</p>
                  <h3 class="text-2xl md:text-3xl font-light mb-4 text-charcoal">
                    <a href="/portfolio/geopolitics" class="hover:text-gold transition">
                      Canada in a Multipolar World
                    </a>
                  </h3>
                  <p class="text-gray-700 leading-relaxed mb-4">
                    Structural analysis of Canada's position within shifting geopolitical alignments, examining how multipolarity reshapes trade relationships, security partnerships, and strategic autonomy.
                  </p>
                  <a href="/portfolio/geopolitics" class="inline-flex items-center text-gold hover:text-gold/80 transition">
                    Read essay →
                  </a>
                </div>
                <div class="md:w-48 text-right text-sm text-gray-500">
                  12 min read
                </div>
              </div>
            </article>

            {/* Resources Essay */}
            <article class="border-b border-gray-200 pb-8 md:pb-12">
              <div class="flex flex-col md:flex-row gap-6 md:gap-12">
                <div class="flex-1">
                  <p class="text-sm text-gray-500 mb-2">PORTFOLIO · FEBRUARY 2026</p>
                  <h3 class="text-2xl md:text-3xl font-light mb-4 text-charcoal">
                    <a href="/portfolio/resources" class="hover:text-gold transition">
                      Critical Minerals and Civilization
                    </a>
                  </h3>
                  <p class="text-gray-700 leading-relaxed mb-4">
                    The role of critical minerals in technological systems, supply chain dependencies, and how resource competition shapes economic and geopolitical outcomes.
                  </p>
                  <a href="/portfolio/resources" class="inline-flex items-center text-gold hover:text-gold/80 transition">
                    Read essay →
                  </a>
                </div>
                <div class="md:w-48 text-right text-sm text-gray-500">
                  14 min read
                </div>
              </div>
            </article>

            {/* Technology Essay */}
            <article class="pb-8 md:pb-12">
              <div class="flex flex-col md:flex-row gap-6 md:gap-12">
                <div class="flex-1">
                  <p class="text-sm text-gray-500 mb-2">PORTFOLIO · JANUARY 2026</p>
                  <h3 class="text-2xl md:text-3xl font-light mb-4 text-charcoal">
                    <a href="/portfolio/technology" class="hover:text-gold transition">
                      AI Governance and Strategic Competition
                    </a>
                  </h3>
                  <p class="text-gray-700 leading-relaxed mb-4">
                    How artificial intelligence governance frameworks reflect broader technological competition and shape state capacity, international relations, and industrial strategy.
                  </p>
                  <a href="/portfolio/technology" class="inline-flex items-center text-gold hover:text-gold/80 transition">
                    Read essay →
                  </a>
                </div>
                <div class="md:w-48 text-right text-sm text-gray-500">
                  10 min read
                </div>
              </div>
            </article>
          </div>

          <div class="mt-12 pt-8 border-t border-gray-200">
            <a href="/analyses" class="inline-flex items-center text-gold hover:text-gold/80 transition text-lg font-light">
              View all analyses →
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Research Approach Section */}
    <section id="research-approach" class="py-16 md:py-24 bg-[#EFEFEF]">
      <div class="container mx-auto px-6 md:px-12">
        <div class="max-w-4xl">
          <h2 class="text-4xl md:text-5xl font-light mb-12 text-charcoal">
            Research Approach
          </h2>

          <div class="space-y-8">
            <div>
              <h3 class="text-xl font-light mb-4 text-charcoal">Method</h3>
              <p class="text-gray-700 leading-relaxed mb-4">
                TransHorizons is an independent analytical initiative focused on understanding how large-scale systems shape geopolitical, economic, and technological outcomes.
              </p>
              <p class="text-gray-700 leading-relaxed">
                Research is based primarily on publicly available institutional and authoritative sources, including national statistical agencies, federal departments, international organizations, and peer-reviewed research.
              </p>
            </div>

            <div>
              <h3 class="text-xl font-light mb-4 text-charcoal">Scope</h3>
              <p class="text-gray-700 leading-relaxed mb-4">
                The work examines interconnected systems across four primary domains:
              </p>
              <ul class="space-y-3 text-gray-700">
                <li class="flex gap-4">
                  <span class="text-gold font-semibold">•</span>
                  <span><strong>Structural systems:</strong> Long-term patterns shaping Canada's development, including geography, resource orientation, and integration into global markets.</span>
                </li>
                <li class="flex gap-4">
                  <span class="text-gold font-semibold">•</span>
                  <span><strong>Material systems:</strong> Resource-based systems such as energy, critical minerals, and forest ecosystems, including their role in industrial and environmental transformations.</span>
                </li>
                <li class="flex gap-4">
                  <span class="text-gold font-semibold">•</span>
                  <span><strong>Technological systems:</strong> Digital infrastructure, artificial intelligence, and governance frameworks shaping emerging forms of economic and political power.</span>
                </li>
                <li class="flex gap-4">
                  <span class="text-gold font-semibold">•</span>
                  <span><strong>Economic and trade systems:</strong> Trade relationships, industrial policy, and supply chain dynamics, particularly within North American and transatlantic contexts.</span>
                </li>
              </ul>
            </div>

            <div>
              <p class="text-gray-700">
                <a href="/research-approach" class="inline-flex items-center text-gold hover:text-gold/80 transition">
                  Full research approach →
                </a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Notes Section */}
    <section id="notes" class="py-16 md:py-24 bg-white">
      <div class="container mx-auto px-6 md:px-12">
        <div class="max-w-4xl">
          <h2 class="text-4xl md:text-5xl font-light mb-12 text-charcoal">
            Research Notes
          </h2>

          <div class="space-y-8">
            <article class="border-b border-gray-200 pb-8">
              <p class="text-sm text-gray-500 mb-2">NOTES · MARCH 2026</p>
              <h3 class="text-2xl font-light mb-3 text-charcoal">
                <a href="/notes/career-evolution" class="hover:text-gold transition">
                  From Translation Toward Research and Analysis
                </a>
              </h3>
              <p class="text-gray-700 leading-relaxed mb-3">
                A reflection on how institutional translation became long-term training in research, curiosity, and analytical writing.
              </p>
              <a href="/notes/career-evolution" class="inline-flex items-center text-gold hover:text-gold/80 transition">
                Read note →
              </a>
            </article>

            <article>
              <p class="text-sm text-gray-500 mb-2">NOTES · APRIL 2026</p>
              <h3 class="text-2xl font-light mb-3 text-charcoal">
                <a href="/notes/travel-observation" class="hover:text-gold transition">
                  Travel Observations and Systemic Reflection
                </a>
              </h3>
              <p class="text-gray-700 leading-relaxed mb-3">
                Observations from recent travels on how different societies organize systems, institutional approaches, and governance challenges.
              </p>
              <a href="/notes/travel-observation" class="inline-flex items-center text-gold hover:text-gold/80 transition">
                Read note →
              </a>
            </article>
          </div>

          <div class="mt-12 pt-8 border-t border-gray-200">
            <a href="/notes" class="inline-flex items-center text-gold hover:text-gold/80 transition text-lg font-light">
              View all notes →
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* About Section */}
    <section id="about" class="py-16 md:py-24 bg-[#EFEFEF]">
      <div class="container mx-auto px-6 md:px-12">
        <div class="max-w-4xl">
          <h2 class="text-4xl md:text-5xl font-light mb-8 text-charcoal">
            About This Project
          </h2>

          <div class="space-y-6 text-gray-700 leading-relaxed">
            <p>
              TransHorizons began as a personal research initiative focused on understanding the structural dynamics shaping Canada's position within evolving global systems. The project combines institutional knowledge, cross-domain synthesis, and systematic monitoring of geopolitical, economic, and technological developments.
            </p>

            <p>
              The goal is to produce accessible analytical work grounded in rigorous research, connecting complex systemic changes to practical implications for policy, business, and public understanding.
            </p>

            <p>
              This site serves as a repository for analytical essays, research notes, visualizations, and tools. All content is independently produced and based on publicly available sources.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Contact Section */}
    <section id="contact" class="py-16 md:py-24 bg-white">
      <div class="container mx-auto px-6 md:px-12">
        <div class="max-w-4xl">
          <h2 class="text-4xl md:text-5xl font-light mb-8 text-charcoal">
            Get in Touch
          </h2>

          <div class="space-y-6">
            <p class="text-gray-700 leading-relaxed">
              Have questions, feedback, or collaboration ideas? Reach out.
            </p>

            <div class="space-y-2">
              <p class="text-gray-700">
                <strong>Email:</strong> <a href="mailto:contact@transhorizons.net" class="text-gold hover:text-gold/80 transition">contact@transhorizons.net</a>
              </p>
              <p class="text-gray-700">
                <strong>LinkedIn:</strong> <a href="https://www.linkedin.com/in/transhorizons" target="_blank" rel="noopener noreferrer" class="text-gold hover:text-gold/80 transition">TransHorizons Profile</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
