---
import Base from '../layouts/Base.astro';
import AppShell from '../components/AppShell';
// Dynamic server rendering for all routes - don't prerender to avoid 3D component errors
export const prerender = false;

// Exclude keystatic routes - let the Keystatic integration handle them
if (Astro.url.pathname.startsWith('/keystatic')) {
  return Astro.reroute(new Request(Astro.request));
}
---
<Base>
  <AppShell client:only="react" />
</Base>
